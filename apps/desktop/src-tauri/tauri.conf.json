{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agent Sync Studio",
  "version": "0.2.0",
  "identifier": "io.jinso.agent-sync-studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agent Sync Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
